# Copy to .env and fill in. Vite inlines VITE_* variables at build time.

# Base URL of the Rust backend API.
VITE_API_BASE_URL=http://localhost:4000

# MapTiler API key for the basemap style (https://cloud.maptiler.com/keys/).
# Optional: without it the map falls back to the keyless MapLibre demo basemap.
# VITE_MAPTILER_API_KEY=
